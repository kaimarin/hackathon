# Copy to .env and fill in values. Never commit .env or apikey files.

ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=your-rocketride-api-key

# LLM keys (use ROCKETRIDE_ prefix in pipeline configs)
ROCKETRIDE_ANTHROPIC_KEY=your-anthropic-api-key

# Supabase (goes in web/.env.local for the Next.js app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
